{
  "manifest_version": 3,
  "name": "Job Board to Notion",
  "description": "Extract job details from supported job boards and save to Notion.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Board to Notion"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://www.cake.me/*",
    "https://www.104.com.tw/*",
    "https://104.com.tw/*",
    "https://m.104.com.tw/*",
    "https://go.104.com.tw/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.cake.me/*",
        "https://www.104.com.tw/*",
        "https://104.com.tw/*",
        "https://m.104.com.tw/*",
        "https://go.104.com.tw/*"
      ],
      "js": [
        "lib/utils.js",
        "content/extractor.js",
        "content/linkedin.js",
        "content/cake.js",
        "content/104.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
